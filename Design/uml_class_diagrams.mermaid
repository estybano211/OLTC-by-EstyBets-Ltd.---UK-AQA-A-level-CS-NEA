    %% ==================== DATABASE LAYER ====================

    class DatabaseManagement {
        SCHEMA
        db_path
        __init__(db_path)
        connect()
        check_database_exists()
        create_database()
        admin_account()
        admin_logged_in()
        admin_accessed_system(system)
        admin_password_check(password)
        change_admin_password(new_password)
        view_database(table)
        export_table_to_csv(table, file_path)
        change_user_record()
        change_user_username(user_id, new_username)
        change_user_password(user_id, new_password)
        change_user_account_type(user_id, registered)
        change_user_balance(user_id, new_balance)
        delete_user_record(user_id)
        fetch_user_record()
        fetch_user_presence(username)
        register_user(username, password, registered)
        verify_user_password(username, password)
        record_user_login(username)
        check_expired_guest_account()
        apply_daily_login_bonus()
        fetch_user_id(username)
        fetch_username(user_id)
        fetch_user_balance(username)
        modify_user_balance(username, new_balance)
        check_user_poker_data_exists(user_id)
        initialise_user_poker_data(user_id)
        load_user_poker_data(user_id)
        update_player_range(user_id, player_range)
        log_player_action(user_id, round_number, street, action, bet_size, pot_size)
        resolve_player_actions(user_id, round_number)
        update_hand_statistics(user_id, action, bet_size, voluntarily_entered, preflop_raised, faced_raise)
        recalculate_frequencies(conn, user_id)
        fetch_total_rounds(user_id)
        fetch_tournament_scores()
        update_tournament_best(user_id)
    }

