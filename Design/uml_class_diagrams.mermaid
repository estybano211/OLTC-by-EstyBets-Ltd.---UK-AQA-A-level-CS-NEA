    %% ==================== GAMES ====================

    class WhiteJoe {
        bet_var
        current_bet
        dbm
        dealer
        dealer_hand
        deck
        player_hand
        start_balance
        user_data
        wj_root
        __init__(user_data)
        admin_modify_bet(frame)
        whitejoe_screen(frame)
        update_button_states()
        log_message(text, round_start, is_win, is_loss, is_push)
        process_log_queue()
        render_log(text, round_start, is_win, is_loss, is_push)
        return_balance()
        check_balance()
        modify_user_balance(balance)
        start_round()
        logs_after_deal()
        hit()
        stand()
        double_down()
        surrender()
        resolve_dealer()
        end_round(win, loss, push)
        return_to_menu(is_error, error)
    }

    class TournamentManager {
        base_big_blind
        base_small_blind
        current_round
        human_starting_balance
        round_wins
        rounds_survived
        target_amount
        total_players
        total_rounds
        tournament_over
        tournament_won
        win_criteria
        __init__(settings)
        current_small_blind()
        current_big_blind()
        advance_round(human_won_round)
        fetch_status_text()
    }

    class HarrogateHoldEm {
        board
        bots
        current_bet
        dbm
        deck
        hhe_root
        player_count
        player_go
        player_turn
        players
        pot_size
        round_active
        round_number
        street
        street_sequence
        tournament_mode
        user_data
        __init__(user_data, settings, bots)
        admin_modify_bet(frame)
        harrogate_hold_em_screen(frame)
        update_player_status()
        update_ui()
        update_labels()
        update_button_states()
        reset_players()
        modify_player(player, cards, change_balance, bet, status, refresh_player_model)
        log_message(text, round_start, is_win, is_loss, tie, is_thinking, is_tournament)
        process_log_queue()
        render_log(text, round_start, is_win, is_loss, tie, is_thinking, is_tournament)
        return_balance()
        check_balance()
        modify_user_balance(balance)
        log_player_action_to_db(action, bet_size)
        check_round()
        blind_management()
        distribute_cards()
        play_round()
        decisions()
        start_bot_decision_queue(player)
        bot_decision_worker(player, min_thinking_ms)
        check_bot_decision_queue()
        bot_decision(player)
        execute_bot_decision(player, decision)
        is_betting_complete()
        reset_after_raise(except_player)
        bot_error(player, error)
        get_community_cards()
        next_street()
        advance_street()
        showdown()
        update_user_poker_data()
        end_round(win, loss, tie, split_pot, split_count)
        finish_tournament(result)
        finish_end_round()
        check_game_over()
        fold()
        call()
        raise_bet()
        return_to_menu(is_error, error)
    }

    %% ==================== POKER PLAYER MODELS ====================

    class HumanPokerPlayer {
        active_range
        aggression_factor
        base_range
        call_when_weak
        dbm
        fold_to_raise
        pfr
        record
        statistics
        stored_range
        user_id
        vpip
        __init__(user_id)
        refresh_from_db()
        reset_active_range()
        update_range_from_action(action, hand_notation)
        fetch_player_info()
    }

    class BotPokerPlayer {
        active_range
        aggression_factor
        base_range
        bluff_freq
        bot_characteristics
        call_when_weak
        difficulty
        fold_to_raise
        pfr
        vpip
        __init__(difficulty)
        decide(player_hand, community_cards, opponents, pot, to_call, balance, street)
        fetch_player_info()
    }

    class BotCharacteristics {
        bluff_multiplier
        difficulty
        fold_bias
        is_bot
        mdf_threshold
        noise_level
        range_adherence
        risk_tolerance
        simulations
        __init__(difficulty)
    }

    %% ==================== RELATIONSHIPS ====================

    %% Inheritance
    LogHandler <|-- DatabaseLogHandler
    LogHandler <|-- AdminLogHandler
    BaseInterface <|-- AdminInterface
    BaseInterface <|-- AdminConsole
    BaseInterface <|-- CasinoInterface

    %% DatabaseManagement composition
    DatabaseManagement --o BaseInterface : dbm
    DatabaseManagement --o WhiteJoe : dbm
    DatabaseManagement --o HarrogateHoldEm : dbm
    DatabaseManagement --o HumanPokerPlayer : dbm
    DatabaseManagement --o EncryptionSoftware : dbm

    %% CasinoInterface launches games
    CasinoInterface ..> WhiteJoe : starts
    CasinoInterface ..> HarrogateHoldEm : starts
    CasinoInterface ..> ShowGameRules : uses

    %% AdminInterface navigation
    AdminInterface ..> AdminConsole : opens
    AdminInterface ..> CasinoInterface : opens

    %% AdminConsole uses EncryptionSoftware
    AdminConsole ..> EncryptionSoftware : opens

    %% HarrogateHoldEm owns a TournamentManager
    TournamentManager --o HarrogateHoldEm : tournament

    %% Games use CasinoDeckManager
    CasinoDeckManager --o HarrogateHoldEm : deck
    CasinoDeckManager --o WhiteJoe : deck

    %% HarrogateHoldEm uses player models
    HumanPokerPlayer --o HarrogateHoldEm : players model
    BotPokerPlayer --o HarrogateHoldEm : players model

    %% BotPokerPlayer owns BotCharacteristics
    BotCharacteristics --o BotPokerPlayer : bot_characteristics
